<main class="document-window-page">
  <%= turbo_frame_tag @terminal_frame_id do %>
    <section
      class="document-window"
      aria-label="Document terminal"
      data-controller="doc-editor"
      data-doc-editor-save-path-value="<%= doc_path(@document) %>"
    >
      <header class="document-window__toolbar" aria-label="Document toolbar">
        <div class="document-window__toolbar-group document-window__toolbar-group--nav">
          <%= render "shared/window_action_button", kind: "up", namespace: "document-window" %>
          <%= render "shared/window_action_button", kind: "back", namespace: "document-window" %>
          <%= render "shared/window_action_button", kind: "delete", namespace: "document-window" %>
        </div>

        <h1 class="document-window__title"><%= @document.title %></h1>

        <div class="document-window__toolbar-group document-window__toolbar-group--actions">
          <%= render "shared/window_action_button", kind: "new_folder", namespace: "document-window" %>
          <%= render "shared/window_action_button", kind: "new_document", namespace: "document-window" %>
        </div>
      </header>

      <div class="document-window__body">
        <div
          class="doc-terminal-content"
          contenteditable="true"
          data-doc-editor-target="content"
          data-action="input->doc-editor#handleInput keydown->doc-editor#handleKeydown"
        ><%= sanitize(@document.editor_html, tags: %w[p br], attributes: %w[data-element]) %></div>
        <footer class="document-window__status-bar" aria-label="Terminal status bar">
          <%= render "shared/ig_select",
            name: "insert_block_type",
            id: "insert-block-type",
            selected: "scene_heading",
            options: [
              { label: "Scene Heading", value: "scene_heading" },
              { label: "Action", value: "action" },
              { label: "Character", value: "character" },
              { label: "Dialogue", value: "dialogue" },
              { label: "Parenthetical", value: "parenthetical" },
              { label: "Transition", value: "transition" }
            ],
            action_button: {
              label: "Insert",
              position: "right",
              variant: "primary",
              data: { action: "doc-editor#insertElement" }
            },
            width: "14rem" %>
          <div class="document-window__status-meta">
            <span class="document-window__save-status" aria-label="Save status">
              <span
                class="document-window__save-light"
                data-doc-editor-target="statusLight"
                data-state="idle"
                aria-hidden="true"
              ></span>
            </span>
            <span>manuscript://docs/<%= @document.id %></span>
            <span>Ln 1, Col 1</span>
          </div>
        </footer>
      </div>
    </section>
  <% end %>
</main>
