<%
  document_menu_contexts = {
    document_page: {
      menus: [
        {
          label: "File",
          items: [
            { type: "link", label: "Home", href: root_path },
            { type: "link", label: "New Draft", href: documents_path, shortcut: "⌘N" },
            { type: "separator" },
            { type: "action", label: "Save", action: "save-document", disabled: true, shortcut: "⌘S" }
          ]
        },
        {
          label: "Edit",
          items: [
            { type: "action", label: "Undo", action: "undo", disabled: true, shortcut: "⌘Z" },
            { type: "action", label: "Cut", action: "cut", disabled: true, shortcut: "⌘X" },
            { type: "action", label: "Copy", action: "copy", disabled: true, shortcut: "⌘C" },
            { type: "action", label: "Paste", action: "paste", disabled: true, shortcut: "⌘V" }
          ]
        },
        {
          label: "Format",
          items: [
            {
              type: "submenu",
              label: "Insert",
              items: [
                { type: "action", label: "Scene Heading", action: "insert-scene-heading", disabled: true },
                { type: "action", label: "Dialogue", action: "insert-dialogue", disabled: true }
              ]
            }
          ]
        }
      ]
    }
  }

  content_for :menu_bar_contexts, document_menu_contexts.to_json
  content_for :menu_bar_default_context, "document_page"
  content_for :menu_bar_current_context, "document_page"
%>

<main class="doc-terminal-page">
  <%= turbo_frame_tag @terminal_frame_id do %>
    <section
      class="doc-terminal-screen"
      aria-label="Document terminal"
      data-controller="doc-editor"
      data-doc-editor-save-path-value="<%= doc_path(@document) %>"
    >
      <h1 class="doc-terminal-title"><%= @document.title %></h1>
      <div
        class="doc-terminal-content"
        contenteditable="true"
        data-doc-editor-target="content"
        data-action="input->doc-editor#handleInput keydown->doc-editor#handleKeydown"
      ><%= sanitize(@document.editor_html, tags: %w[p br], attributes: %w[data-element]) %></div>
      <footer class="doc-terminal-bottom-bar" aria-label="Terminal status bar">
        <%= render "shared/ig_select",
          name: "insert_block_type",
          id: "insert-block-type",
          selected: "scene_heading",
          options: [
            { label: "Scene Heading", value: "scene_heading" },
            { label: "Action", value: "action" },
            { label: "Character", value: "character" },
            { label: "Dialogue", value: "dialogue" },
            { label: "Parenthetical", value: "parenthetical" },
            { label: "Transition", value: "transition" }
          ],
          action_button: {
            label: "Insert",
            position: "right",
            variant: "primary",
            data: { action: "doc-editor#insertElement" }
          },
          width: "14rem" %>
        <div class="doc-terminal-bottom-meta">
          <span class="doc-terminal-save-status" aria-label="Save status">
            <span
              class="doc-terminal-save-light"
              data-doc-editor-target="statusLight"
              data-state="idle"
              aria-hidden="true"
            ></span>
          </span>
          <span>manuscript://docs/<%= @document.id %></span>
          <span>Ln 1, Col 1</span>
        </div>
      </footer>
    </section>
  <% end %>
</main>
