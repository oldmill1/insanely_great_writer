<%
  desktop_menu_contexts = {
    desktop: {
      menus: [
        {
          label: "File",
          items: [
            { type: "link", label: "New Draft", href: documents_path, shortcut: "⌘N" },
            { type: "action", label: "New Note", action: "new-note", disabled: !user_signed_in? },
            { type: "separator" },
            { type: "link", label: user_signed_in? ? "Account" : "Login", href: user_signed_in? ? root_path : new_user_session_path }
          ]
        },
        {
          label: "View",
          items: [
            { type: "action", label: "Desktop", action: "focus-desktop" },
            { type: "action", label: "Documents", action: "focus-documents", disabled: true },
            { type: "separator" },
            {
              type: "submenu",
              label: "Arrange Icons",
              items: [
                { type: "action", label: "By Name", action: "arrange-icons-name", disabled: true },
                { type: "action", label: "By Date", action: "arrange-icons-date", disabled: true }
              ]
            }
          ]
        },
        {
          label: "Special",
          items: [
            { type: "action", label: "Empty Trash", action: "empty-trash", disabled: true }
          ]
        }
      ]
    },
    document_window: {
      menus: [
        {
          label: "File",
          items: [
            { type: "link", label: "New Draft", href: documents_path, shortcut: "⌘N" },
            { type: "action", label: "Close Window", action: "close-active-window", shortcut: "⌘W" },
            { type: "action", label: "Open in Full Page", action: "open-active-window-page" }
          ]
        },
        {
          label: "Edit",
          items: [
            { type: "action", label: "Undo", action: "undo", disabled: true, shortcut: "⌘Z" },
            { type: "action", label: "Cut", action: "cut", disabled: true, shortcut: "⌘X" },
            { type: "action", label: "Copy", action: "copy", disabled: true, shortcut: "⌘C" },
            { type: "action", label: "Paste", action: "paste", disabled: true, shortcut: "⌘V" }
          ]
        },
        {
          label: "Window",
          items: [
            { type: "action", label: "Bring All to Front", action: "bring-all-to-front", disabled: true },
            {
              type: "submenu",
              label: "Recent Documents",
              items: [
                { type: "action", label: "Current Draft", action: "recent-document-current", disabled: true },
                { type: "action", label: "Another Draft", action: "recent-document-other", disabled: true }
              ]
            }
          ]
        }
      ]
    }
  }

  content_for :menu_bar_contexts, desktop_menu_contexts.to_json
  content_for :menu_bar_default_context, "desktop"
  content_for :menu_bar_current_context, "desktop"
%>

<main
  class="home"
  data-controller="home-context-menu"
  data-home-context-menu-login-path-value="<%= new_user_session_path %>"
  data-home-context-menu-register-path-value="<%= new_user_registration_path %>"
  data-home-context-menu-logout-path-value="<%= destroy_user_session_path %>"
  data-action="
    contextmenu->home-context-menu#open
    pointerdown->home-context-menu#close
    keydown.esc@window->home-context-menu#closeWithEscape
  "
>
  <h1 class="home__title">manuscriptOS</h1>
  <section
    class="home__desktop"
    aria-label="Desktop"
    data-controller="desktop"
    data-action="click->desktop#select"
    data-desktop-shortcuts-value="<%= json_escape(@desktop_shortcuts.to_json) %>"
  ></section>

  <% @desktop_windows.each do |window| %>
    <%= render "shared/ig_window",
      window_key: window[:window_key],
      title: window[:title],
      content: window[:content],
      content_src: window[:content_src],
      content_frame_id: window[:content_frame_id],
      x: window[:x],
      y: window[:y],
      width: window[:width],
      height: window[:height] %>
  <% end %>

  <div class="home__dock" aria-label="Application dock">
    <%= render "shared/ig_dock",
      items: [
        { thumbnail: "/icons/write.png", label: "New Draft", intent: "new_draft", kind: "action", path: documents_path },
        { thumbnail: "/icons/scene.png", label: "New Scene", intent: "new_scene", kind: "action" }
      ] %>
  </div>

  <% @notes.each do |note| %>
    <%= render "desktop_note", note: note %>
  <% end %>

  <div
    class="home__context-menu"
    data-home-context-menu-target="menu"
    data-action="click->home-context-menu#handleMenuClick"
    hidden
  >
    <%= render "shared/ig_menu", items: @context_menu_items %>
  </div>
</main>
