<main class="folder-window-page">
  <%= turbo_frame_tag @frame_id do %>
    <%
      items = @children[:folders].map do |child|
        {
          id: child.id,
          name: child.name,
          kind: "Folder",
          kind_rank: 0,
          created_at: child.created_at,
          updated_at: child.updated_at
        }
      end + @children[:documents].map do |child|
        {
          id: child.id,
          name: child.title,
          kind: "Document",
          kind_rank: 1,
          created_at: child.created_at,
          updated_at: child.updated_at
        }
      end

      items.sort_by! { |item| [item[:kind_rank], item[:name].to_s.downcase] }
    %>

    <section
      class="folder-window"
      aria-label="Folder window"
      data-controller="folder-browser"
      data-folder-browser-folder-id-value="<%= @folder.id %>"
      data-folder-browser-folder-name-value="<%= @folder.name %>"
      data-folder-browser-folder-path-value="<%= @folder.path %>"
      data-folder-browser-create-folder-path-value="<%= folders_path %>"
      data-folder-browser-create-document-path-value="<%= documents_path %>"
      data-folder-browser-show-path-value="<%= folder_path(@folder) %>"
    >
      <header class="folder-window__toolbar">
        <div class="folder-window__actions">
          <%= button_tag "New Folder",
            type: "button",
            class: "ig-button",
            data: { action: "folder-browser#createFolder" } %>
          <%= button_tag "New Document",
            type: "button",
            class: "ig-button ig-button--subtle",
            data: { action: "folder-browser#createDocument" } %>
        </div>
      </header>

      <div class="folder-window__groups">
        <% if items.any? %>
          <section class="folder-window__group" aria-labelledby="folder-group-items">
            <div class="folder-window__table" role="table" aria-label="Folder contents">
              <div class="folder-window__header" role="row">
                <button
                  type="button"
                  class="folder-window__sort-button is-active"
                  role="columnheader"
                  aria-sort="none"
                  data-folder-browser-target="sortButton"
                  data-action="folder-browser#sortBy"
                  data-sort-key="name"
                >Name</button>
                <button
                  type="button"
                  class="folder-window__sort-button"
                  role="columnheader"
                  aria-sort="ascending"
                  data-folder-browser-target="sortButton"
                  data-action="folder-browser#sortBy"
                  data-sort-key="kind"
                >Kind</button>
                <button
                  type="button"
                  class="folder-window__sort-button"
                  role="columnheader"
                  aria-sort="none"
                  data-folder-browser-target="sortButton"
                  data-action="folder-browser#sortBy"
                  data-sort-key="created"
                >Date Created</button>
                <button
                  type="button"
                  class="folder-window__sort-button"
                  role="columnheader"
                  aria-sort="none"
                  data-folder-browser-target="sortButton"
                  data-action="folder-browser#sortBy"
                  data-sort-key="modified"
                >Date Modified</button>
              </div>

              <div class="folder-window__list" data-folder-browser-target="list">
                <% items.each do |item| %>
                  <% icon_path = item[:kind] == "Folder" ? "/icons/folders/default.png" : "/icons/write.png" %>
                  <button
                    type="button"
                    class="folder-window__row"
                    data-folder-browser-target="row"
                    data-action="dblclick->folder-browser#openItem"
                    data-item-kind="<%= item[:kind].downcase %>"
                    data-item-id="<%= item[:id] %>"
                    data-item-name="<%= item[:name] %>"
                    data-sort-name="<%= item[:name].to_s.downcase %>"
                    data-sort-kind="<%= item[:kind_rank] %>"
                    data-sort-created="<%= item[:created_at]&.iso8601 %>"
                    data-sort-modified="<%= item[:updated_at]&.iso8601 %>"
                  >
                    <span class="folder-window__cell folder-window__cell--name">
                      <img class="folder-window__icon" src="<%= icon_path %>" alt="" aria-hidden="true">
                      <span class="folder-window__name-text"><%= item[:name] %></span>
                    </span>
                    <span class="folder-window__cell folder-window__cell--kind"><%= item[:kind] %></span>
                    <span class="folder-window__cell"><%= item[:created_at]&.strftime("%Y-%m-%d %H:%M") %></span>
                    <span class="folder-window__cell"><%= item[:updated_at]&.strftime("%Y-%m-%d %H:%M") %></span>
                  </button>
                <% end %>
              </div>
            </div>
          </section>
        <% else %>
          <section class="folder-window__group" aria-labelledby="folder-group-items">
            <p class="folder-window__empty">No items yet.</p>
          </section>
        <% end %>
      </div>

      <footer class="folder-window__status-bar" aria-label="Folder path">
        <span class="folder-window__status-label">Path</span>
        <span class="folder-window__status-value"><%= @folder.path %></span>
      </footer>
    </section>
  <% end %>
</main>
